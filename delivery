# Use Form Requests

Never validate inside controllers for larger projects.

Create:

```bash
php artisan make:request AssignDeliveryRequest
```

```php
<?php

namespace App\Http\Requests;

use Illuminate\Foundation\Http\FormRequest;

class AssignDeliveryRequest extends FormRequest
{
    public function authorize(): bool
    {
        return true;
    }

    public function rules(): array
    {
        return [
            'order_id' => [
                'required',
                'exists:orders,id'
            ],
            'driver_id' => [
                'required',
                'exists:drivers,id'
            ]
        ];
    }
}
```

